# ============================================================
# MEMI — Root environment file (consumed by docker-compose.yml)
# Copy this to .env and fill in your values. NEVER commit the real .env.
# Full reference (every var, what breaks if wrong): docs/ENVIRONMENT.md
# Canonical domain: memi.testdemo.it · admin.memi.testdemo.it · api.memi.testdemo.it
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=choose_a_strong_root_password
DB_NAME=memi_db
DB_USER=memi_user
DB_PASSWORD=choose_a_strong_user_password

# ── JWT secrets — REQUIRED (backend refuses to boot without them) ─────────────
# generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_64_char_hex_here
JWT_ADMIN_SECRET=generate_different_64_char_hex_here

# ── Domains (used by the Traefik labels in docker-compose.yml) ───────────────
SHOP_DOMAIN=memi.testdemo.it
ADMIN_DOMAIN=admin.memi.testdemo.it
API_DOMAIN=api.memi.testdemo.it

# ── CORS + frontend URL (must match the domains above) ───────────────────────
ALLOWED_ORIGINS=https://memi.testdemo.it,https://www.memi.testdemo.it,https://admin.memi.testdemo.it
FRONTEND_URL=https://memi.testdemo.it

# ── Admin bootstrap — set a strong password; prod refuses to boot on the default ──
ADMIN_EMAIL=admin@memi.it
ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password
# ALLOW_DEFAULT_ADMIN=1   # escape hatch only (INSECURE) — boot in prod with default creds

# ── Stripe — card checkout is disabled (503) until these are set ─────────────
# Klarna ("Paga in 3 rate") ALSO rides on Stripe — there is NO separate Klarna key.
# Once Stripe is set, enable Klarna in Stripe Dashboard → Settings → Payment methods
# (test and live modes are separate). Until it's enabled there, the storefront Klarna
# tab shows "non disponibile" even though the code is fully wired.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook endpoint: https://api.memi.testdemo.it/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# ── PayPal — checkout hides PayPal and the API returns 503 until these are set ─
# Get REST API credentials at developer.paypal.com → Apps & Credentials (create an app).
# ⚠️  PAYPAL_ENV MUST match the credential type: a Sandbox app → sandbox, a Live app →
#     live. A mismatch (e.g. sandbox credentials with PAYPAL_ENV=live) fails auth on
#     every PayPal call because the server hits the wrong API host.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox

# SumUp (card payments — replaces Stripe Elements on the card tab when set)
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
# Required for live PayPal: webhook id used to verify webhook signatures. Without it,
# PayPal webhook events are acknowledged but never used to change order state.
PAYPAL_WEBHOOK_ID=

# ── SMTP / email — all emails are silent no-ops until SMTP_USER is set ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Memi Abbigliamento <info@memi.testdemo.it>"

# ── Product image uploads ────────────────────────────────────────────────────
MAX_UPLOAD_MB=8
