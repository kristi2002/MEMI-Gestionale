# ============================================================
# MEMI — Root environment file
# Copy this to .env and fill in your values.
# NEVER commit the real .env to git.
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=choose_a_strong_root_password
DB_NAME=memi_db
DB_USER=memi_user
DB_PASSWORD=choose_a_strong_user_password

# ── JWT secrets (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=generate_64_char_hex_here
JWT_ADMIN_SECRET=generate_different_64_char_hex_here

# ── CORS (comma-separated list of your frontend domains)
ALLOWED_ORIGINS=https://memi.testdemo.it,https://www.memi.testdemo.it,https://admin.memi.testdemo.it

# ── Domains (used in DEPLOYMENT.md instructions)
SHOP_DOMAIN=memi.testdemo.it
ADMIN_DOMAIN=admin.memi.testdemo.it
API_DOMAIN=api.memi.testdemo.it
