# ── Database ──────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=memi_user
DB_PASSWORD=changeme_strong_password
DB_NAME=memi_db

# ── JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_hex_secret_for_customers
JWT_ADMIN_SECRET=replace_with_different_64_char_hex_secret_for_admins
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Structured (pino) log level: trace|debug|info|warn|error|fatal. Defaults to "info".
LOG_LEVEL=info

# ── CORS: comma-separated list of allowed frontend origins ────
ALLOWED_ORIGINS=https://memi.testdemo.it,https://www.memi.testdemo.it,https://admin.memi.testdemo.it

# ── Stripe (get keys from https://dashboard.stripe.com/apikeys) ──────────────
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
# Webhook signing secret — create an endpoint at https://dashboard.stripe.com/webhooks
# pointed at https://<your-api-domain>/api/payments/webhook, subscribed to at least
# payment_intent.succeeded and charge.dispute.created. Without this, the webhook
# endpoint responds 503 to every event (fails safe, doesn't crash the server).
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── PayPal (scaffolding — optional) ───────────────────────────────────────
# Leave unset until a merchant account exists. With no credentials the checkout
# hides PayPal and the provider endpoints return 503 (nothing breaks).
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_ENV=sandbox            # sandbox | live

# ── SMTP / email (nodemailer) ─────────────────────────────────────────────
# If SMTP_USER is unset, ALL emails (order confirmation, shipping, welcome,
# password reset, gift-card delivery) are silent no-ops — the app still works,
# but customers get no email. Required for a real store.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Memi Abbigliamento <info@memi.testdemo.it>"

# ── Frontend URL (used in emails for reset-password links) ────────────────
FRONTEND_URL=https://memi.testdemo.it

# ── Product image uploads ─────────────────────────────────────────────────
UPLOADS_DIR=/app/uploads
MAX_UPLOAD_MB=8

# ── Admin bootstrap (READ AT STARTUP) ──────────────────────────────────────
# If BOTH ADMIN_EMAIL and ADMIN_PASSWORD are set, the backend upserts this admin
# account with a freshly hashed password every boot (src/db/migrations.js →
# bootstrapAdmin). This is the supported way to set/rotate the admin login.
#
# schema.sql still seeds a default admin (admin@memi.it / "memi2026admin") on a
# brand-new database. Keeping ADMIN_EMAIL=admin@memi.it below rotates THAT row's
# password. In PRODUCTION the backend now REFUSES TO BOOT if any admin still carries
# the shipped default password — set a strong ADMIN_PASSWORD before going live
# (or, only for a throwaway staging box, set ALLOW_DEFAULT_ADMIN=1 to bypass — not recommended).
ADMIN_EMAIL=admin@memi.it
ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password
# ALLOW_DEFAULT_ADMIN=1   # escape hatch: boot in prod even with default admin creds (INSECURE)
